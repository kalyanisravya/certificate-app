<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      margin: 0;
      padding: 20px;
      background: #f4f4f9;
      color: #333;
    }

    h1, h2 {
      text-align: center;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 20px;
      padding: 20px;
    }

    .card {
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      padding: 15px;
      transition: transform 0.3s;
    }

    .card:hover {
      transform: scale(1.02);
    }

    video {
      width: 100%;
      border-radius: 10px;
      margin-bottom: 10px;
    }

    .completed {
      color: green;
      font-weight: bold;
      margin: 5px 0;
    }

    .not-completed {
      color: red;
      font-weight: bold;
      margin: 5px 0;
    }

    form {
      display: inline;
    }

    button {
      padding: 8px 14px;
      background-color: #007bff;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      margin-bottom: 8px;
    }

    button:hover {
      background-color: #0056b3;
    }

    .quiz-btn {
      display: block;
      margin: 30px auto;
      padding: 12px 25px;
      background-color: #28a745;
      color: white;
      font-size: 16px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }

    .quiz-btn:hover {
      background-color: #218838;
    }

    .message {
      text-align: center;
      font-size: 18px;
      margin-top: 30px;
    }
  </style>
</head>
<body>
  <h1>Welcome, <%= user.name %>!</h1>
  <h2>📽️ Your Learning Videos</h2>

  <div class="grid">
    <% videos.forEach(video => { %>
      <div class="card">
        <video controls>
          <source src="/videos/<%= video %>" type="video/mp4">
          Your browser does not support the video tag.
        </video>
        <% if (completed.includes(video)) { %>
          <p class="completed">✔ Completed</p>
        <% } else { %>
          <form action="/complete" method="post">
            <input type="hidden" name="video" value="<%= video %>">
            <button type="submit">Mark as Completed</button>
          </form>
          <p class="not-completed"> Not Completed</p>
        <% } %>
      </div>
    <% }); %>
  </div>

  <% if (allCompleted) { %>
    <div class="message">
      <p style="color: green;">🎉 You've completed all videos!</p>
      <a href="/quiz">
        <button class="quiz-btn">Start Quiz</button>
      </a>
    </div>
  <% } else { %>
    <div class="message">
      <p style="color: red;">❗ Watch and complete all videos to unlock the quiz.</p>
    </div>
  <% } %>
</body>
</html>
