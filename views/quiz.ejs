<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Quiz</title>
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(to right, #FAD0C4, #FFD1FF);
      padding: 40px;
      display: flex;
      justify-content: center;
    }

    .quiz-container {
      background-color: white;
      padding: 40px;
      border-radius: 15px;
      max-width: 800px;
      width: 100%;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    h2, #timer {
      text-align: center;
      color: #5D3FD3;
      margin-bottom: 20px;
    }

    .question {
      margin-bottom: 25px;
      background-color: #f3f3f3;
      padding: 15px 20px;
      border-radius: 10px;
    }

    .question p {
      font-weight: bold;
      color: #333;
    }

    label {
      display: block;
      margin: 8px 0;
      background-color: #fff;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid #ccc;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    input[type="radio"] {
      margin-right: 10px;
    }

    label:hover {
      background-color: #e6f0ff;
      border-color: #5D3FD3;
    }

    button {
      display: block;
      margin: 30px auto 0;
      padding: 12px 30px;
      background-color: #5D3FD3;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      cursor: pointer;
      transition: background-color 0.3s ease;
    }

    button:hover {
      background-color: #472bbd;
    }
  </style>
</head>
<body>

  <div class="quiz-container">
    <h2>🧪 Quiz</h2>
    <h3 id="timer">Time Left: 10:00</h3>

    <form id="quizForm" action="/submit-quiz" method="POST">
      <% quiz.forEach((q, i) => { %>
        <div class="question">
          <p><%= i + 1 %>. <%= q.question %></p>
          <% q.options.forEach(option => { %>
            <label>
              <input type="radio" name="q<%= i %>" value="<%= option %>" required>
              <%= option %>
            </label>
          <% }) %>
        </div>
      <% }) %>
      <input type="hidden" name="total" value="<%= quiz.length %>">
      <button type="submit">🚀 Submit Quiz</button>
    </form>
  </div>

  <script>
    let timeLeft = 600; // 10 minutes
    const timerDisplay = document.getElementById("timer");

    const countdown = setInterval(() => {
      const minutes = Math.floor(timeLeft / 60);
      const seconds = timeLeft % 60;
      timerDisplay.innerText = `Time Left: ${minutes}:${seconds.toString().padStart(2, '0')}`;

      timeLeft--;
      if (timeLeft < 0) {
        clearInterval(countdown);
        document.getElementById("quizForm").submit();
      }
    }, 1000);
  </script>
</body>
</html>
